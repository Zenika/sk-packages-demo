{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>Zenika/sk-packages-tools//packages/renovate/default"
  ],
  "branchPrefix": "renovate-",
  "lockFileMaintenance": {
    "enabled": true
  },
  "prConcurrentLimit": 10,
  "recreateWhen": "never",
  "platformAutomerge": true,
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "osvVulnerabilityAlerts": true,
  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "minimumReleaseAge": "3 days"
    },
    {
      "matchUpdateTypes": ["patch"],
      "addLabels": ["PATCH"],
      "automerge": true,
      "automergeStrategy": "squash"
    },
    {
      "matchDatasources": ["npm"],
      "matchCategories": ["security"],
      "commitMessageSuffix": "\uD83D\uDEA8",
      "commitMessagePrefix": "fix(dependencies/security): "
    },
    {
      "commitMessagePrefix": "chore(dependencies): ",
      "addLabels": [
        "\uD83D\uDC40 Tech review needed"
      ],
      "matchManagers": ["npm"]
    },
    {
      "commitMessagePrefix": "chore(dependencies/tools): ",
      "addLabels": [
        "\uD83D\uDC40 Tech review needed"
      ],
      "matchManagers": ["npm"],
      "matchPackageNames": ["eslint", "prettier"],
      "groupName": "Format & lint Tools",
      "groupSlug": "format-lint-tools"
    }
  ]
}
